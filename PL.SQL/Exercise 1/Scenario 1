COMMIT;
SET SERVEROUTPUT ON;

DECLARE
    CURSOR customer_cursor IS
        SELECT c.customer_id,
               c.name,
               c.age,
               l.loan_id,
               l.interest_rate
        FROM customers c
        JOIN loans l
        ON c.customer_id = l.customer_id;

BEGIN
    FOR customer_record IN customer_cursor LOOP

        -- Check if customer's age is above 60
        IF customer_record.age > 60 THEN

            -- Apply 1% discount on loan interest rate
            UPDATE loans
            SET interest_rate = interest_rate - 1
            WHERE loan_id = customer_record.loan_id;

            DBMS_OUTPUT.PUT_LINE(
                'Discount applied to ' ||
                customer_record.name ||
                '. New Interest Rate = ' ||
                (customer_record.interest_rate - 1) || '%'
            );

        END IF;

    END LOOP;

    COMMIT;

    DBMS_OUTPUT.PUT_LINE('Interest rates updated successfully.');

END;
