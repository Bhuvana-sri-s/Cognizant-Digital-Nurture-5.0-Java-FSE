CREATE TABLE customers (
    customer_id NUMBER PRIMARY KEY,
    name VARCHAR2(50)
);
CREATE TABLE loans (
    loan_id NUMBER PRIMARY KEY,
    customer_id NUMBER,
    loan_amount NUMBER(10,2),
    due_date DATE,
    FOREIGN KEY(customer_id)
    REFERENCES customers(customer_id)
);
