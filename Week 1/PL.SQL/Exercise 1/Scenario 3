COMMIT;
SET SERVEROUTPUT ON;

DECLARE

    CURSOR loan_cursor IS

    SELECT c.name,
           l.loan_id,
           l.due_date
    FROM customers c
    JOIN loans l
    ON c.customer_id=l.customer_id
    WHERE l.due_date BETWEEN SYSDATE AND SYSDATE+30;

BEGIN

    FOR loan_record IN loan_cursor LOOP

        DBMS_OUTPUT.PUT_LINE(
        'Reminder: Dear '||
        loan_record.name||
        ', your Loan ID '||
        loan_record.loan_id||
        ' is due on '||
        TO_CHAR(loan_record.due_date,'DD-MON-YYYY')
        );

    END LOOP;

END;
